generator client {
  provider        = "prisma-client-js"
  output          = "../generated/prisma"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["management"]
}

model admins {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  firebase_uid String   @unique @db.VarChar(128)
  name         String   @db.VarChar(255)
  email        String   @db.VarChar(255)
  status       String   @default("active") @db.VarChar(16)
  created_at   DateTime @default(now()) @db.Timestamptz(6)

  @@schema("management")
}

model audit_logs {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id     String?  @db.Uuid
  actor_id      String   @db.Uuid
  action        String   @db.VarChar(128)
  resource_type String   @db.VarChar(64)
  resource_id   String?  @db.Uuid
  metadata      Json?
  created_at    DateTime @default(now()) @db.Timestamptz(6)

  @@index([actor_id, created_at], map: "audit_logs_actor_idx")
  @@index([tenant_id, resource_type, resource_id], map: "audit_logs_tenant_resource_idx")
  @@schema("management")
}

model contracts {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String          @db.Uuid
  monthly_value   Decimal         @db.Decimal(10, 2)
  modules         String[]        @default([])
  max_vehicles    Int             @default(0)
  max_drivers     Int             @default(0)
  max_managers    Int             @default(0)
  starts_at       DateTime        @db.Date
  ends_at         DateTime?       @db.Date
  status          contract_status @default(active)
  created_at      DateTime        @default(now()) @db.Timestamptz(6)
  organizations   organizations   @relation(fields: [organization_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  invoices        invoices[]

  @@index([organization_id, status], map: "contracts_org_status_idx")
  @@schema("management")
}

model gestor_invites {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id  String    @db.Uuid
  token      String    @unique @db.VarChar(128)
  email      String?   @db.VarChar(255)
  expires_at DateTime  @db.Timestamptz(6)
  used_at    DateTime? @db.Timestamptz(6)
  created_by String    @db.Uuid
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  tenants    tenants   @relation(fields: [tenant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("management")
}

model invoices {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contract_id      String         @db.Uuid
  competence_month DateTime       @db.Date
  value            Decimal        @db.Decimal(10, 2)
  status           invoice_status @default(pending)
  paid_at          DateTime?      @db.Timestamptz(6)
  paid_by          String?        @db.Uuid
  created_at       DateTime       @default(now()) @db.Timestamptz(6)
  contracts        contracts      @relation(fields: [contract_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([contract_id, competence_month], map: "invoices_contract_month_unique")
  @@schema("management")
}

model licenses {
  id                      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id               String   @unique(map: "licenses_tenant_unique") @db.Uuid
  max_vehicles            Int      @default(0)
  max_drivers             Int      @default(0)
  max_managers            Int      @default(0)
  synced_from_contract_id String?  @db.Uuid
  updated_at              DateTime @default(now()) @db.Timestamptz(6)
  tenants                 tenants  @relation(fields: [tenant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("management")
}

model modules {
  id              String           @id @db.VarChar(64)
  name            String           @db.VarChar(255)
  dependencies    String[]         @default([])
  dependency_type dep_type?
  tenant_modules  tenant_modules[]

  @@schema("management")
}

model organizations {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id       String      @unique(map: "organizations_tenant_unique") @db.Uuid
  razao_social    String      @db.VarChar(255)
  cnpj            String      @unique(map: "organizations_cnpj_unique") @db.VarChar(18)
  financial_email String      @db.VarChar(255)
  billing_address Json?
  created_at      DateTime    @default(now()) @db.Timestamptz(6)
  updated_at      DateTime    @default(now()) @db.Timestamptz(6)
  contracts       contracts[]
  tenants         tenants     @relation(fields: [tenant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("management")
}

model outbox_events {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  aggregate_type String   @db.VarChar(64)
  aggregate_id   String   @db.Uuid
  event_type     String   @db.VarChar(128)
  payload        Json
  published      Boolean  @default(false)
  created_at     DateTime @default(now()) @db.Timestamptz(6)

  @@schema("management")
}

model tenant_metrics {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id       String   @db.Uuid
  date            DateTime @db.Date
  login_count     Int      @default(0)
  execution_count Int      @default(0)
  request_count   Int      @default(0)
  tenants         tenants  @relation(fields: [tenant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([tenant_id, date], map: "tenant_metrics_date_unique")
  @@schema("management")
}

model tenant_modules {
  tenant_id  String   @db.Uuid
  module_id  String   @db.VarChar(64)
  enabled    Boolean  @default(false)
  updated_at DateTime @default(now()) @db.Timestamptz(6)
  modules    modules  @relation(fields: [module_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tenants    tenants  @relation(fields: [tenant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@id([tenant_id, module_id])
  @@schema("management")
}

model tenants {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  city           String           @db.VarChar(255)
  state          String           @db.Char(2)
  status         tenant_status    @default(active)
  created_at     DateTime         @default(now()) @db.Timestamptz(6)
  updated_at     DateTime         @default(now()) @db.Timestamptz(6)
  gestor_invites gestor_invites[]
  licenses       licenses?
  organizations  organizations?
  tenant_metrics tenant_metrics[]
  tenant_modules tenant_modules[]

  @@unique([city, state], map: "tenants_city_state_unique")
  @@schema("management")
}

enum contract_status {
  active
  suspended
  terminated

  @@schema("management")
}

enum dep_type {
  required
  exclusive_group

  @@schema("management")
}

enum invite_role {
  manager

  @@schema("management")
}

enum invoice_status {
  pending
  paid
  cancelled

  @@schema("management")
}

enum tenant_status {
  active
  suspended
  inactive

  @@schema("management")
}

enum user_role {
  superadmin
  manager

  @@schema("management")
}
