JWT_REFRESH_EXPIRY=7d
MANAGEMENT_PORT=3000

# === app-api ===
# (DATABASE_URL, FIREBASE_* e JWT_* idênticos ao management-api)
MAPBOX_TOKEN=pk.eyJ1...
WHATSAPP_API_TOKEN=your-whatsapp-token
APP_PORT=3001
